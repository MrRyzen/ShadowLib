# Unity asset/import metadata is required at the package root for asmdefs and
# samples to be recognised, BUT not in /Library or /Temp scratch dirs (covered
# above). Per Unity guidance, .meta files for committed assets should be
# tracked. They are NOT ignored here.

# Generated Unity project files — these are derived from .asmdef + Library/
*.csproj.user
*.unityproj
*.sln.DotSettings*
sysinfo.txt
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity package tarballs from local pack
*.tgz

# Crashes
crashlytics-build.properties
*.stackdump

